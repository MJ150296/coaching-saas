{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.ts",
    "src/app/api/admin/coaching-*.ts",
    "src/app/api/admin/coaching-*/**/*.ts",
    "src/app/api/admin/enrollments/route.ts",
    "src/app/api/admin/timetable/route.ts",
    "src/app/api/admin/generate-recurring-fees/route.ts",
    "src/app/api/admin/fee-*.ts",
    "src/app/api/admin/fee-*/**/*.ts",
    "src/app/api/admin/student-fee-ledger/route.ts",
    "src/app/api/admin/student-ledger/route.ts",
    "src/app/api/admin/payments/route.ts",
    "src/app/api/admin/credit-notes/route.ts",
    "src/shared/bootstrap/**/*.ts",
    "src/shared/domain/**/*.ts",
    "src/shared/infrastructure/**/*.ts",
    "src/shared/lib/**/*.ts",
    "src/domains/academic-management/**/*.ts",
    "src/domains/coaching-management/**/*.ts",
    "src/domains/fee-management/**/*.ts",
    "src/domains/user-management/**/*.ts",
    "src/domains/organization-management/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
