{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/app/admin-roles/**/*.ts",
    "src/app/admin-roles/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/shared/components/**/*.ts",
    "src/shared/components/**/*.tsx",
    "src/shared/lib/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
