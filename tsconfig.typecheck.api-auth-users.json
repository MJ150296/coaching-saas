{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "next-env.d.ts",
    "src/types/**/*.ts",
    "src/app/page.tsx",
    "src/app/api/auth/**/*.ts",
    "src/app/api/users/**/*.ts",
    "src/app/api/dev/seed-test-user/route.ts",
    "src/app/api/bootstrap/init/route.ts",
    "src/shared/bootstrap/**/*.ts",
    "src/shared/domain/**/*.ts",
    "src/shared/infrastructure/**/*.ts",
    "src/shared/lib/utils.ts",
    "src/domains/user-management/**/*.ts",
    "src/domains/organization-management/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
