{
  "name": "coaching-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "npm run type-check:chunked",
    "type-check:all": "tsc --noEmit --pretty false",
    "type-check:api": "npm run type-check:api-routes:individual",
    "type-check:api-routes:individual": "node scripts/type-check-api-routes.cjs",
    "type-check:admin-panels": "NODE_OPTIONS=--max-old-space-size=4096 tsc -p tsconfig.typecheck.admin-panels.json --pretty false",
    "type-check:admin-pages:individual": "node scripts/type-check-admin-pages.cjs",
    "type-check:chunked": "npm run type-check:api && npm run type-check:admin-panels",
    "migrate:coaching-center-id": "node scripts/migrate-school-to-coaching-center.cjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.564.0",
    "mongoose": "^9.1.6",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
